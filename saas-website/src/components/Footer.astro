---
import { Phone, Twitter, Linkedin, Github } from '@lucide/astro';

const currentYear = new Date().getFullYear();

const footerSections = {
  industries: [
    { href: '/industries/real-estate', label: 'Real Estate' },
    { href: '/industries/healthcare', label: 'Healthcare' },
    { href: '/industries/financial-services', label: 'Financial Services' },
    { href: '/industries/insurance', label: 'Insurance' },
    { href: '/industries/logistics-transportation', label: 'Logistics & Transportation' },
    { href: '/industries/home-services', label: 'Home Services' },
    { href: '/industries/retail-consumer', label: 'Retail & Consumer' },
    { href: '/industries/travel-hospitality', label: 'Travel & Hospitality' },
    { href: '/industries/debt-collection', label: 'Debt Collection' },
    { href: '/industries/recruitment', label: 'Recruitment' },
    { href: '/industries/voice-ai-for-crms', label: 'Voice AI for CRMs' },
    { href: '/industries/telecom', label: 'Telecom' },
  ],
  useCases: [
    { href: '/use-cases/lead-qualification', label: 'Lead Qualification' },
    { href: '/use-cases/lead-generation', label: 'Lead Generation' },
    { href: '/use-cases/customer-support', label: 'Customer Support' },
    { href: '/use-cases/ai-receptionist', label: 'AI Receptionist' },
    { href: '/use-cases/call-follow-up-automation', label: 'Call Follow-Ups' },
    { href: '/use-cases/abandoned-cart-recovery', label: 'Cart Recovery' },
    { href: '/use-cases/product-announcements', label: 'Product Announcements' },
    { href: '/use-cases/survey-nps-calls', label: 'Survey & NPS Calls' },
    { href: '/use-cases/payment-reminders', label: 'Payment Reminders' },
  ],
  company: [
    { href: '/about', label: 'About' },
    { href: '/pricing', label: 'Pricing' },
    { href: '/integrations', label: 'Integrations' },
    { href: '/contact', label: 'Contact' },
  ],
  legal: [
    { href: '/privacy-policy', label: 'Privacy Policy' },
    { href: '/terms', label: 'Terms & Conditions' },
    { href: '/cookies', label: 'Cookie Policy' },
  ],
};
---

<footer class="bg-surface-alt border-t border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8 lg:gap-12">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-3 lg:col-span-2">
        <a href="/" class="flex items-center gap-2.5 mb-5">
          <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-primary to-secondary flex items-center justify-center">
            <Phone class="w-5 h-5 text-white" />
          </div>
          <span class="text-xl font-bold font-display text-text">Vox<span class="text-primary">eia</span></span>
        </a>
        <p class="text-text-muted text-sm leading-relaxed max-w-sm mb-6">
          AI-powered voice agents that automate your outreach, qualify leads, and scale business communications — 24/7,
          in any language.
        </p>
        <div class="flex gap-3">
          <a
            href="#"
            class="w-9 h-9 rounded-lg bg-surface-raised border border-border flex items-center justify-center text-text-muted hover:text-primary hover:border-primary/30 transition-all"
            aria-label="Twitter"
          >
            <Twitter class="w-4 h-4" />
          </a>
          <a
            href="#"
            class="w-9 h-9 rounded-lg bg-surface-raised border border-border flex items-center justify-center text-text-muted hover:text-primary hover:border-primary/30 transition-all"
            aria-label="LinkedIn"
          >
            <Linkedin class="w-4 h-4" />
          </a>
          <a
            href="#"
            class="w-9 h-9 rounded-lg bg-surface-raised border border-border flex items-center justify-center text-text-muted hover:text-primary hover:border-primary/30 transition-all"
            aria-label="GitHub"
          >
            <Github class="w-4 h-4" />
          </a>
        </div>
      </div>

      <!-- Industry -->
      <div>
        <h3 class="text-text font-semibold text-sm mb-4">Industry</h3>
        <ul class="space-y-2.5">
          {
            footerSections.industries.map((link) => (
              <li>
                <a href={link.href} class="text-text-muted hover:text-primary transition-colors text-sm">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Use Cases -->
      <div>
        <h3 class="text-text font-semibold text-sm mb-4">Use Cases</h3>
        <ul class="space-y-2.5">
          {
            footerSections.useCases.map((link) => (
              <li>
                <a href={link.href} class="text-text-muted hover:text-primary transition-colors text-sm">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-text font-semibold text-sm mb-4">Company</h3>
        <ul class="space-y-2.5">
          {
            footerSections.company.map((link) => (
              <li>
                <a href={link.href} class="text-text-muted hover:text-primary transition-colors text-sm">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-text font-semibold text-sm mb-4">Legal</h3>
        <ul class="space-y-2.5">
          {
            footerSections.legal.map((link) => (
              <li>
                <a href={link.href} class="text-text-muted hover:text-primary transition-colors text-sm">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
        <div class="mt-6">
          <h3 class="text-text font-semibold text-sm mb-3">Contact</h3>
          <p class="text-text-muted text-sm">hello@voxeia.com</p>
          <p class="text-text-muted text-sm mt-1">100% Remote Company</p>
        </div>
      </div>
    </div>

    <div class="border-t border-border mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-text-light text-sm">&copy; {currentYear} Voxeia. All rights reserved.</p>
      <p class="text-text-light text-sm">Made with ❤️ remotely, across the globe</p>
    </div>
  </div>
</footer>
