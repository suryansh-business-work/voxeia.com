---
import {
  Phone,
  PhoneCall,
  Brain,
  Volume2,
  Mic,
  Cloud,
  Database,
  ClipboardList,
  Zap,
  MessageSquare,
  Link2,
  Code,
  MessageCircle,
  Users,
  UserCheck,
  Rocket,
  Bot,
  BarChart3,
  Settings,
  Mail,
  Video,
  Globe,
  Clock,
  Check,
  ChevronDown,
  Search,
  ArrowRight,
  ChevronRight,
  Edit,
  Shield,
  Briefcase,
  Truck,
  Home,
  ShoppingCart,
  Server,
  Repeat,
  DollarSign,
  Megaphone,
  Target,
  RefreshCw,
  Bell,
  Gift,
  CreditCard,
  Clipboard,
  Wifi,
  AlertTriangle,
  Calendar,
  Quote,
  Table,
  Pill,
  Wand2,
  Palette,
} from '@lucide/astro';

interface Props {
  name: string;
  class?: string;
}
const { name, class: cls = 'w-6 h-6' } = Astro.props;

const icons: Record<string, any> = {
  phone: Phone,
  'phone-call': PhoneCall,
  brain: Brain,
  'volume-2': Volume2,
  mic: Mic,
  cloud: Cloud,
  database: Database,
  'clipboard-list': ClipboardList,
  zap: Zap,
  'message-square': MessageSquare,
  'link-2': Link2,
  code: Code,
  'message-circle': MessageCircle,
  users: Users,
  'user-check': UserCheck,
  rocket: Rocket,
  bot: Bot,
  'bar-chart-3': BarChart3,
  chart: BarChart3,
  'bar-chart': BarChart3,
  settings: Settings,
  mail: Mail,
  video: Video,
  globe: Globe,
  clock: Clock,
  check: Check,
  'chevron-down': ChevronDown,
  search: Search,
  'arrow-right': ArrowRight,
  'chevron-right': ChevronRight,
  edit: Edit,
  shield: Shield,
  briefcase: Briefcase,
  truck: Truck,
  home: Home,
  cart: ShoppingCart,
  server: Server,
  repeat: Repeat,
  dollar: DollarSign,
  megaphone: Megaphone,
  target: Target,
  refresh: RefreshCw,
  bell: Bell,
  gift: Gift,
  creditcard: CreditCard,
  clipboard: Clipboard,
  wifi: Wifi,
  alert: AlertTriangle,
  calendar: Calendar,
  quote: Quote,
  table: Table,
  pill: Pill,
  wand: Wand2,
  palette: Palette,
};

const IconComp = (icons[name] ?? Zap) as any;
---

<IconComp class={cls} />
