---
import { ChevronDown, Menu, X } from '@lucide/astro';

const navLinks = [
  { href: '/', label: 'Home' },
  {
    label: 'Industries',
    children: [
      { href: '/industries/real-estate', label: 'Real Estate' },
      { href: '/industries/healthcare', label: 'Healthcare' },
      { href: '/industries/financial-services', label: 'Financial Services' },
      { href: '/industries/insurance', label: 'Insurance' },
      { href: '/industries/logistics-transportation', label: 'Logistics & Transportation' },
      { href: '/industries/home-services', label: 'Home Services' },
      { href: '/industries/retail-consumer', label: 'Retail & Consumer' },
      { href: '/industries/travel-hospitality', label: 'Travel & Hospitality' },
      { href: '/industries/debt-collection', label: 'Debt Collection' },
      { href: '/industries/recruitment', label: 'Recruitment' },
      { href: '/industries/voice-ai-for-crms', label: 'Voice AI for CRMs' },
      { href: '/industries/telecom', label: 'Telecom' },
    ],
  },
  {
    label: 'Use Cases',
    children: [
      { href: '/use-cases/lead-qualification', label: 'Lead Qualification' },
      { href: '/use-cases/lead-generation', label: 'Lead Generation' },
      { href: '/use-cases/customer-support', label: 'Customer Support' },
      { href: '/use-cases/ai-receptionist', label: 'AI Receptionist' },
      { href: '/use-cases/call-follow-up-automation', label: 'Call Follow-Up Automation' },
      { href: '/use-cases/abandoned-cart-recovery', label: 'Abandoned Cart Recovery' },
      { href: '/use-cases/product-announcements', label: 'Product Announcements' },
      { href: '/use-cases/survey-nps-calls', label: 'Survey and NPS Calls' },
      { href: '/use-cases/payment-reminders', label: 'Payment Reminders' },
    ],
  },
  { href: '/integrations', label: 'Integrations' },
  { href: '/pricing', label: 'Pricing' },
  {
    label: 'Company',
    children: [
      { href: '/about', label: 'About' },
      { href: '/contact', label: 'Contact' },
    ],
  },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-surface/80 backdrop-blur-2xl border-b border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <a href="/" class="flex items-center gap-2 group shrink-0">
        <img src="/logo-header.png" alt="Voxeia" class="h-8 sm:h-9 w-auto" />
      </a>

      <div class="hidden lg:flex items-center gap-1">
        {
          navLinks.map((link) =>
            'children' in link ? (
              <div class="relative group">
                <button class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-text-muted hover:text-text transition-colors rounded-lg hover:bg-surface-raised">
                  {link.label}
                  <ChevronDown class="w-3.5 h-3.5 opacity-50 group-hover:opacity-100 transition-all group-hover:rotate-180" />
                </button>
                <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                  <div class="w-64 rounded-xl bg-surface-card border border-border shadow-2xl shadow-black/20 py-2 max-h-[70vh] overflow-y-auto">
                    {link.children?.map((child) => (
                      <a
                        href={child.href}
                        class="block px-4 py-2.5 text-sm text-text-muted hover:text-text hover:bg-surface-raised transition-colors"
                      >
                        {child.label}
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            ) : (
              <a
                href={link.href}
                class="px-3 py-2 text-sm font-medium text-text-muted hover:text-text transition-colors rounded-lg hover:bg-surface-raised"
              >
                {link.label}
              </a>
            ),
          )
        }
      </div>

      <div class="hidden lg:flex items-center gap-3">
        <a
          href="https://app.voxeia.com"
          class="px-3 py-2 text-sm font-medium text-text-muted hover:text-text transition-colors">Sign In</a
        >
        <a
          href="https://app.voxeia.com"
          class="px-5 py-2.5 text-sm font-semibold text-white bg-gradient-to-r from-primary to-primary-dark rounded-full hover:shadow-lg hover:shadow-primary/25 transition-all hover:-translate-y-0.5"
          >Get Started</a
        >
      </div>

      <button id="mobile-menu-btn" class="lg:hidden text-text-muted hover:text-text p-2" aria-label="Toggle menu">
        <Menu id="menu-icon-open" class="w-6 h-6" />
        <X id="menu-icon-close" class="w-6 h-6 hidden" />
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden bg-surface-card border-b border-border max-h-[80vh] overflow-y-auto">
    <div class="px-4 py-4 space-y-1">
      {
        navLinks.map((link) =>
          'children' in link ? (
            <div class="mobile-dropdown">
              <button class="mobile-dropdown-btn flex items-center justify-between w-full px-4 py-3 text-text-muted hover:text-text rounded-lg transition-colors">
                <span>{link.label}</span>
                <ChevronDown class="w-4 h-4 transition-transform" />
              </button>
              <div class="mobile-dropdown-content hidden pl-4 space-y-1">
                {link.children?.map((child) => (
                  <a
                    href={child.href}
                    class="block px-4 py-2.5 text-sm text-text-muted hover:text-text hover:bg-surface-raised rounded-lg transition-colors"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class="block px-4 py-3 text-text-muted hover:text-text hover:bg-surface-raised rounded-lg transition-colors"
            >
              {link.label}
            </a>
          ),
        )
      }
      <div class="pt-3 space-y-2 border-t border-border mt-3">
        <a href="https://app.voxeia.com" class="block px-4 py-3 text-center text-text-muted hover:text-text rounded-lg"
          >Sign In</a
        >
        <a
          href="https://app.voxeia.com"
          class="block px-4 py-3 text-center text-white bg-gradient-to-r from-primary to-primary-dark rounded-xl font-semibold"
          >Get Started</a
        >
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  btn?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !isHidden);
    iconClose?.classList.toggle('hidden', isHidden);
  });
  document.querySelectorAll('.mobile-dropdown-btn').forEach((b) => {
    b.addEventListener('click', () => {
      const content = b.nextElementSibling as HTMLElement;
      const arrow = b.querySelector('svg');
      content?.classList.toggle('hidden');
      arrow?.classList.toggle('rotate-180');
    });
  });
</script>
