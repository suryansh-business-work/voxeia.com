---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { Check, ChevronDown } from '@lucide/astro';

const benefits = [
  {
    icon: 'dollar',
    title: '30% Recurring Commission',
    description: 'Earn 30% of every payment your referrals make — for the lifetime of their subscription.',
  },
  {
    icon: 'gift',
    title: '90-Day Cookie Window',
    description:
      'Generous 90-day attribution window. If they click your link today and sign up in 3 months, you still earn.',
  },
  {
    icon: 'chart',
    title: 'Real-Time Dashboard',
    description: 'Track clicks, signups, conversions, and earnings in your personal affiliate dashboard.',
  },
  {
    icon: 'palette',
    title: 'Marketing Materials',
    description: 'Access banners, email templates, case studies, and landing page copy — ready to use.',
  },
  {
    icon: 'user-check',
    title: 'Dedicated Manager',
    description: 'Top affiliates get a dedicated affiliate manager for strategy, custom deals, and support.',
  },
  {
    icon: 'creditcard',
    title: 'Monthly Payouts',
    description: 'Reliable monthly payouts via bank transfer, PayPal, or Wise. Minimum threshold of $50.',
  },
];

const tiers = [
  {
    name: 'Starter',
    range: '1-10 referrals/month',
    commission: '25%',
    perks: ['Self-serve dashboard', 'Standard marketing materials', 'Email support'],
  },
  {
    name: 'Growth',
    range: '11-50 referrals/month',
    commission: '30%',
    perks: ['Everything in Starter', 'Custom landing pages', 'Priority support', 'Quarterly bonus'],
  },
  {
    name: 'Elite',
    range: '50+ referrals/month',
    commission: '35%',
    perks: [
      'Everything in Growth',
      'Dedicated affiliate manager',
      'Custom commission rates',
      'Co-marketing opportunities',
      'Early product access',
    ],
  },
];

const steps = [
  {
    step: 1,
    title: 'Apply',
    description: 'Fill out our quick application form. We review all applications within 48 hours.',
  },
  {
    step: 2,
    title: 'Get Approved',
    description: 'Once approved, access your dashboard with unique referral links and marketing materials.',
  },
  {
    step: 3,
    title: 'Share & Promote',
    description: 'Share Voxeia through your blog, social media, email list, or community.',
  },
  {
    step: 4,
    title: 'Earn',
    description: "Earn recurring commission for every paying customer you refer. It's that simple.",
  },
];

const faqs = [
  {
    q: 'Who can join the affiliate program?',
    a: 'Anyone! We welcome bloggers, YouTubers, agency owners, consultants, SaaS reviewers, and technology enthusiasts. No minimum audience size required.',
  },
  {
    q: 'How do I track my referrals?',
    a: 'You get a unique referral link and access to a real-time dashboard showing clicks, signups, active subscriptions, and earned commissions.',
  },
  {
    q: 'When do I get paid?',
    a: 'Commissions are calculated monthly and paid out on the 15th of the following month. Minimum payout threshold is $50.',
  },
  {
    q: 'Is there a limit to how much I can earn?',
    a: 'No cap! Some of our top affiliates earn $5,000+ per month. The more quality referrals you send, the more you earn.',
  },
  {
    q: 'What if a customer cancels?',
    a: 'Commissions are based on active subscriptions. If a referral cancels, you stop earning on that account. But you keep all previously earned commissions.',
  },
];
---

<Layout
  title="Affiliate Program"
  description="Earn 30% recurring commission by referring businesses to Voxeia's AI voice platform."
>
  <section class="relative pt-32 pb-20 overflow-hidden gradient-mesh">
    <div class="absolute inset-0 grid-pattern"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-sm font-semibold text-primary uppercase tracking-wider">Affiliate Program</span>
      <h1 class="mt-3 text-4xl sm:text-5xl lg:text-6xl font-black font-display text-text">
        Earn <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">30% recurring</span> commissions
      </h1>
      <p class="mt-4 text-lg text-text-muted max-w-2xl mx-auto">
        Join the Voxeia affiliate program and earn lifetime recurring commissions for every customer you refer.
      </p>
      <div class="mt-8">
        <a
          href="/contact"
          class="px-8 py-4 text-white font-semibold bg-gradient-to-r from-primary to-primary-dark rounded-full hover:shadow-lg hover:shadow-primary/25 transition-all hover:-translate-y-0.5 inline-block"
          >Apply Now</a
        >
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-primary uppercase tracking-wider">Benefits</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold font-display text-text">Why partners love our program</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          benefits.map((b) => (
            <div class="p-8 rounded-2xl bg-surface-card border border-border hover:shadow-lg hover:shadow-primary/5 transition-all">
              <div class="p-3 rounded-2xl bg-primary/10 w-fit mb-4">
                <Icon name={b.icon} class="w-6 h-6 text-primary" />
              </div>
              <h3 class="mt-4 text-xl font-bold font-display text-text">{b.title}</h3>
              <p class="mt-2 text-text-muted leading-relaxed">{b.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Tiers -->
  <section class="py-24 bg-surface-alt border-y border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-primary uppercase tracking-wider">Commission Tiers</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold font-display text-text">
          The more you refer, the more you earn
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {
          tiers.map((tier, i) => (
            <div
              class:list={[
                'relative rounded-2xl p-8 flex flex-col transition-all',
                i === 1
                  ? 'bg-gradient-to-b from-primary/10 to-surface-card border-2 border-primary/30 shadow-xl shadow-primary/10'
                  : 'bg-surface-card border border-border',
              ]}
            >
              {i === 1 && (
                <div class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1 bg-gradient-to-r from-primary to-secondary rounded-full text-xs font-bold text-white uppercase tracking-wider">
                  Popular
                </div>
              )}
              <h3 class="text-xl font-bold font-display text-text">{tier.name}</h3>
              <p class="text-sm text-text-muted mt-1">{tier.range}</p>
              <div class="mt-6 mb-8">
                <span class="text-5xl font-black text-text font-display">{tier.commission}</span>
                <span class="text-text-muted ml-1">recurring</span>
              </div>
              <ul class="space-y-3 flex-1">
                {tier.perks.map((perk) => (
                  <li class="flex items-center gap-3 text-sm text-text-muted">
                    <Check class="w-5 h-5 text-success shrink-0" />
                    {perk}
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-sm font-semibold text-primary uppercase tracking-wider">How It Works</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold font-display text-text">Start earning in 4 simple steps</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 max-w-5xl mx-auto">
        {
          steps.map((s) => (
            <div class="text-center">
              <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary to-secondary flex items-center justify-center text-white text-xl font-black font-display mx-auto">
                {s.step}
              </div>
              <h3 class="mt-4 text-lg font-bold font-display text-text">{s.title}</h3>
              <p class="mt-2 text-sm text-text-muted">{s.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-24 bg-surface-alt border-y border-border">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold font-display text-text">Frequently asked questions</h2>
      </div>
      <div class="space-y-4">
        {
          faqs.map((faq) => (
            <details class="group rounded-2xl bg-surface-card border border-border overflow-hidden hover:shadow-md hover:shadow-primary/5 transition-shadow">
              <summary class="flex items-center justify-between cursor-pointer p-6 text-text font-medium hover:bg-surface-raised transition-colors">
                <span>{faq.q}</span>
                <ChevronDown class="w-5 h-5 text-text-muted group-open:rotate-180 transition-transform shrink-0 ml-4" />
              </summary>
              <div class="px-6 pb-6 text-text-muted leading-relaxed">{faq.a}</div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold font-display text-text">Ready to start earning?</h2>
      <p class="mt-4 text-lg text-text-muted">
        Apply today and get approved within 48 hours. Start earning recurring commissions immediately.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a
          href="/contact"
          class="px-8 py-4 text-white font-semibold bg-gradient-to-r from-primary to-primary-dark rounded-full hover:shadow-lg hover:shadow-primary/25 transition-all hover:-translate-y-0.5"
          >Apply Now</a
        >
        <a
          href="/contact"
          class="px-8 py-4 text-text font-semibold bg-surface-raised border border-border rounded-full hover:border-primary/30 transition-all hover:-translate-y-0.5"
          >Ask a Question</a
        >
      </div>
    </div>
  </section>
</Layout>
