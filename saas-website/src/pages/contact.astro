---
import Layout from '../layouts/Layout.astro';
import { Mail, Phone, Globe, Calendar } from '@lucide/astro';
---

<Layout title="Contact Us" description="Get in touch with our team. We're 100% remote and always available to help.">
  <section class="relative pt-32 pb-16 overflow-hidden gradient-mesh">
    <div class="absolute inset-0 grid-pattern"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-sm font-semibold text-primary uppercase tracking-wider">Contact</span>
      <h1 class="mt-3 text-4xl sm:text-5xl lg:text-6xl font-black font-display text-text">
        Let's <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">talk</span>
      </h1>
      <p class="mt-4 text-lg text-text-muted max-w-2xl mx-auto">
        Have a question, need a demo, or want a custom quote? Our team is ready to help.
      </p>
    </div>
  </section>

  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <div class="lg:col-span-3">
          <div class="bg-surface-card border border-border rounded-2xl p-8 sm:p-10">
            <h2 class="text-2xl font-bold font-display text-text mb-2">Send us a message</h2>
            <p class="text-text-muted mb-8">Fill out the form and we'll get back to you within 24 hours.</p>
            <form id="contact-form" class="space-y-6">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="firstName" class="block text-sm font-medium text-text mb-2">First name *</label>
                  <input
                    type="text"
                    id="firstName"
                    name="firstName"
                    required
                    class="w-full px-4 py-3 rounded-xl bg-surface-raised border border-border text-text placeholder-text-light focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"
                    placeholder="John"
                  />
                </div>
                <div>
                  <label for="lastName" class="block text-sm font-medium text-text mb-2">Last name *</label>
                  <input
                    type="text"
                    id="lastName"
                    name="lastName"
                    required
                    class="w-full px-4 py-3 rounded-xl bg-surface-raised border border-border text-text placeholder-text-light focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"
                    placeholder="Doe"
                  />
                </div>
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-text mb-2">Work email *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-3 rounded-xl bg-surface-raised border border-border text-text placeholder-text-light focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"
                  placeholder="john@company.com"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-text mb-2">Phone number</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  class="w-full px-4 py-3 rounded-xl bg-surface-raised border border-border text-text placeholder-text-light focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"
                  placeholder="+91 98765 43210"
                />
              </div>
              <div>
                <label for="company" class="block text-sm font-medium text-text mb-2">Company</label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  class="w-full px-4 py-3 rounded-xl bg-surface-raised border border-border text-text placeholder-text-light focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"
                  placeholder="Acme Inc."
                />
              </div>
              <div>
                <label for="subject" class="block text-sm font-medium text-text mb-2">Subject *</label>
                <select
                  id="subject"
                  name="subject"
                  required
                  class="w-full px-4 py-3 rounded-xl bg-surface-raised border border-border text-text focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"
                >
                  <option value="">Select a topic</option>
                  <option value="demo">Request a demo</option>
                  <option value="pricing">Pricing inquiry</option>
                  <option value="integration">Integration help</option>
                  <option value="support">Technical support</option>
                  <option value="partnership">Partnership</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-text mb-2">Message *</label>
                <textarea
                  id="message"
                  name="message"
                  rows={5}
                  required
                  class="w-full px-4 py-3 rounded-xl bg-surface-raised border border-border text-text placeholder-text-light focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors resize-none"
                  placeholder="Tell us about your project..."></textarea>
              </div>
              <button
                type="submit"
                class="w-full px-8 py-4 text-white font-semibold bg-gradient-to-r from-primary to-primary-dark rounded-full hover:shadow-lg hover:shadow-primary/25 transition-all hover:-translate-y-0.5"
                >Send Message</button
              >
            </form>
          </div>
        </div>
        <div class="lg:col-span-2 space-y-8">
          <div class="bg-surface-card border border-border rounded-2xl p-8">
            <h3 class="text-lg font-bold font-display text-text mb-6">Get in touch</h3>
            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="p-3 rounded-xl bg-primary/10">
                  <Mail class="w-5 h-5 text-primary" />
                </div>
                <div>
                  <p class="text-sm text-text-muted">Email</p>
                  <a href="mailto:contact@voxeia.com" class="text-text hover:text-primary transition-colors"
                    >contact@voxeia.com</a
                  >
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="p-3 rounded-xl bg-secondary/10">
                  <Phone class="w-5 h-5 text-secondary" />
                </div>
                <div>
                  <p class="text-sm text-text-muted">Phone</p>
                  <a href="tel:+919999999999" class="text-text hover:text-primary transition-colors">+91-99999-99999</a>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="p-3 rounded-xl bg-accent/10">
                  <Globe class="w-5 h-5 text-accent" />
                </div>
                <div>
                  <p class="text-sm text-text-muted">Location</p>
                  <p class="text-text">100% Remote Company</p>
                  <p class="text-sm text-text-muted">Serving clients worldwide</p>
                </div>
              </div>
            </div>
          </div>
          <div class="bg-surface-card border border-border rounded-2xl p-8">
            <h3 class="text-lg font-bold font-display text-text mb-4">Response time</h3>
            <div class="space-y-4">
              <div class="flex justify-between items-center">
                <span class="text-text-muted text-sm">General inquiries</span>
                <span class="text-sm font-semibold text-text">24 hrs</span>
              </div>
              <div class="h-px bg-border"></div>
              <div class="flex justify-between items-center">
                <span class="text-text-muted text-sm">Demo requests</span>
                <span class="text-sm font-semibold text-text">12 hrs</span>
              </div>
              <div class="h-px bg-border"></div>
              <div class="flex justify-between items-center">
                <span class="text-text-muted text-sm">Technical support</span>
                <span class="text-sm font-semibold text-text">4 hrs</span>
              </div>
              <div class="h-px bg-border"></div>
              <div class="flex justify-between items-center">
                <span class="text-text-muted text-sm">Enterprise priority</span>
                <span class="text-sm font-semibold text-secondary">1 hr</span>
              </div>
            </div>
          </div>
          <div
            class="bg-gradient-to-br from-primary/10 to-secondary/10 border border-primary/20 rounded-2xl p-8 text-center"
          >
            <h3 class="text-lg font-bold font-display text-text mb-2">Need a quick demo?</h3>
            <p class="text-sm text-text-muted mb-4">Book a 15-minute call with our team and see Voxeia in action.</p>
            <a
              href="/"
              class="inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-white bg-gradient-to-r from-primary to-primary-dark rounded-full hover:shadow-lg hover:shadow-primary/25 transition-all hover:-translate-y-0.5"
            >
              <Calendar class="w-4 h-4" />
              Book a Demo
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
