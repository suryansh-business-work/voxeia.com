---
import Layout from '../layouts/Layout.astro';
import { Check, Zap, BarChart3, SlidersHorizontal, Users, ShieldCheck, RefreshCw, Volume2, Pause } from '@lucide/astro';
import HeroStepperForm from '../components/HeroStepperForm/HeroStepperForm';
---

<Layout title="Home">
  <!-- Hero Section with animated background -->
  <section class="hero-animated-bg relative min-h-screen flex items-center overflow-hidden pt-20">
    <div class="absolute inset-0 grid-pattern"></div>
    <div class="absolute inset-0">
      <div class="hero-orb hero-orb-1 absolute top-1/4 left-[10%] w-[400px] h-[400px] rounded-full blur-[150px]"></div>
      <div class="hero-orb hero-orb-2 absolute bottom-1/4 right-[10%] w-[350px] h-[350px] rounded-full blur-[150px]">
      </div>
      <div
        class="hero-orb hero-orb-3 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] rounded-full blur-[150px]"
      >
      </div>
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full py-12 sm:py-16 lg:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 sm:gap-12 lg:gap-16 items-center">
        <!-- Left: Hero Content -->
        <div class="min-w-0">
          <div
            class="inline-flex items-center gap-2 px-3 sm:px-4 py-2 rounded-full bg-primary/10 border border-primary/20 mb-6 sm:mb-8"
          >
            <span class="w-2 h-2 rounded-full bg-success animate-pulse"></span>
            <span class="text-xs sm:text-sm text-text-muted font-medium">GPT-4o Powered Conversations</span>
          </div>

          <h1
            class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-black leading-[1.1] tracking-tight font-display"
          >
            <span class="block text-text">AI Voice Agents</span>
            <span class="block text-text">That Actually</span>
            <span
              class="block bg-gradient-to-r from-primary via-secondary to-primary bg-clip-text text-transparent bg-[length:200%_100%] animate-shimmer"
            >
              Sound Human
            </span>
          </h1>

          <p class="mt-4 sm:mt-6 text-base sm:text-lg text-text-muted leading-relaxed max-w-lg">
            Deploy intelligent AI voice agents that qualify leads, book appointments, handle support, and close deals —
            on autopilot, 24/7, in 20+ languages.
          </p>

          <div class="mt-6 sm:mt-8 flex flex-wrap gap-4 sm:gap-6 text-sm text-text-muted">
            <div class="flex items-center gap-2">
              <Check class="w-5 h-5 text-success" />
              No setup fees
            </div>
            <div class="flex items-center gap-2">
              <Check class="w-5 h-5 text-success" />
              10 min free
            </div>
            <div class="flex items-center gap-2">
              <Check class="w-5 h-5 text-success" />
              Cancel anytime
            </div>
          </div>

          <!-- Audio Sample Player -->
          <div class="mt-8 sm:mt-10">
            <p class="text-xs text-text-light uppercase tracking-wider mb-3">Hear our AI in action</p>
            <button
              id="audio-play-btn"
              class="group flex items-center gap-3 px-5 py-3 rounded-2xl bg-surface-card border border-border hover:border-primary/30 hover:shadow-lg hover:shadow-primary/10 transition-all"
            >
              <div
                class="w-10 h-10 rounded-full bg-gradient-to-r from-primary to-secondary flex items-center justify-center group-hover:scale-110 transition-transform"
              >
                <Volume2 id="audio-icon-play" class="w-5 h-5 text-white" />
                <Pause id="audio-icon-pause" class="w-5 h-5 text-white hidden" />
              </div>
              <div class="text-left">
                <p class="text-sm font-semibold text-text">AI Voice Sample</p>
                <p class="text-xs text-text-muted" id="audio-status">Click to play</p>
              </div>
              <div class="ml-2 flex items-center gap-0.5" id="audio-bars">
                <span class="w-1 h-3 bg-primary/30 rounded-full"></span>
                <span class="w-1 h-5 bg-primary/30 rounded-full"></span>
                <span class="w-1 h-4 bg-primary/30 rounded-full"></span>
                <span class="w-1 h-6 bg-primary/30 rounded-full"></span>
                <span class="w-1 h-3 bg-primary/30 rounded-full"></span>
              </div>
            </button>
            <audio id="audio-sample" preload="none">
              <source src="/audio/sample.mp3" type="audio/mpeg" />
            </audio>
          </div>
        </div>

        <!-- Right: Stepper Form -->
        <div class="relative min-w-0">
          <div class="absolute -inset-1 bg-gradient-to-r from-primary/10 to-secondary/10 rounded-3xl blur-xl"></div>
          <div class="relative rounded-2xl bg-white border border-border p-4 sm:p-6 md:p-8 shadow-xl shadow-primary/5">
            <HeroStepperForm client:only="react" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="relative py-16 sm:py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16">
        <span class="text-sm font-semibold text-primary uppercase tracking-wider">Features</span>
        <h2 class="mt-3 text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold font-display text-text">
          Everything you need to <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent"
            >scale calls</span
          >
        </h2>
        <p class="mt-4 text-text-muted text-base sm:text-lg">
          Enterprise-grade AI calling infrastructure built for businesses of all sizes.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
        <div
          class="group relative p-6 sm:p-8 rounded-2xl bg-surface-card border border-border hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300"
        >
          <div
            class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary/15 to-secondary/15 flex items-center justify-center text-primary mb-5 group-hover:scale-110 transition-transform"
          >
            <Zap class="w-6 h-6" />
          </div>
          <h3 class="text-lg sm:text-xl font-semibold text-text mb-3 font-display">Lightning Fast Setup</h3>
          <p class="text-text-muted leading-relaxed text-sm sm:text-base">
            Get started in minutes, not days. Configure AI calling campaigns with zero technical knowledge.
          </p>
        </div>

        <div
          class="group relative p-6 sm:p-8 rounded-2xl bg-surface-card border border-border hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300"
        >
          <div
            class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary/15 to-secondary/15 flex items-center justify-center text-primary mb-5 group-hover:scale-110 transition-transform"
          >
            <BarChart3 class="w-6 h-6" />
          </div>
          <h3 class="text-lg sm:text-xl font-semibold text-text mb-3 font-display">Real-time Analytics</h3>
          <p class="text-text-muted leading-relaxed text-sm sm:text-base">
            Monitor call performance, conversion rates, and customer sentiment with comprehensive dashboards.
          </p>
        </div>

        <div
          class="group relative p-6 sm:p-8 rounded-2xl bg-surface-card border border-border hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300"
        >
          <div
            class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary/15 to-secondary/15 flex items-center justify-center text-primary mb-5 group-hover:scale-110 transition-transform"
          >
            <SlidersHorizontal class="w-6 h-6" />
          </div>
          <h3 class="text-lg sm:text-xl font-semibold text-text mb-3 font-display">Fully Customizable</h3>
          <p class="text-text-muted leading-relaxed text-sm sm:text-base">
            Tailor AI voice, scripts, and conversation flows. Supports 20+ languages and regional accents.
          </p>
        </div>

        <div
          class="group relative p-6 sm:p-8 rounded-2xl bg-surface-card border border-border hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300"
        >
          <div
            class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary/15 to-secondary/15 flex items-center justify-center text-primary mb-5 group-hover:scale-110 transition-transform"
          >
            <Users class="w-6 h-6" />
          </div>
          <h3 class="text-lg sm:text-xl font-semibold text-text mb-3 font-display">Smart Lead Qualification</h3>
          <p class="text-text-muted leading-relaxed text-sm sm:text-base">
            AI automatically qualifies leads based on conversation context, saving hours of manual follow-ups.
          </p>
        </div>

        <div
          class="group relative p-6 sm:p-8 rounded-2xl bg-surface-card border border-border hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300"
        >
          <div
            class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary/15 to-secondary/15 flex items-center justify-center text-primary mb-5 group-hover:scale-110 transition-transform"
          >
            <ShieldCheck class="w-6 h-6" />
          </div>
          <h3 class="text-lg sm:text-xl font-semibold text-text mb-3 font-display">Enterprise Security</h3>
          <p class="text-text-muted leading-relaxed text-sm sm:text-base">
            Bank-grade encryption, SOC 2 compliance, and GDPR ready. Your data stays safe.
          </p>
        </div>

        <div
          class="group relative p-6 sm:p-8 rounded-2xl bg-surface-card border border-border hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300"
        >
          <div
            class="w-12 h-12 rounded-xl bg-gradient-to-br from-primary/15 to-secondary/15 flex items-center justify-center text-primary mb-5 group-hover:scale-110 transition-transform"
          >
            <RefreshCw class="w-6 h-6" />
          </div>
          <h3 class="text-lg sm:text-xl font-semibold text-text mb-3 font-display">Auto Retries & Scheduling</h3>
          <p class="text-text-muted leading-relaxed text-sm sm:text-base">
            Smart retry logic and advanced scheduling ensures maximum contact rates. Never miss an opportunity.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it Works -->
  <section class="relative py-16 sm:py-24 lg:py-32 bg-surface-alt border-y border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16">
        <span class="text-sm font-semibold text-primary uppercase tracking-wider">How It Works</span>
        <h2 class="mt-3 text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold font-display text-text">
          Three simple steps to <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent"
            >get started</span
          >
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8">
        <div class="relative text-center p-6 sm:p-8">
          <div
            class="w-14 h-14 sm:w-16 sm:h-16 mx-auto rounded-2xl bg-gradient-to-br from-primary to-secondary flex items-center justify-center text-xl sm:text-2xl font-black text-white mb-5 sm:mb-6 shadow-lg shadow-primary/20 font-display"
          >
            1
          </div>
          <h3 class="text-lg sm:text-xl font-semibold text-text mb-3 font-display">Upload Contacts</h3>
          <p class="text-text-muted text-sm sm:text-base">
            Import your contact list via CSV or connect your CRM. We support all major platforms.
          </p>
        </div>
        <div class="relative text-center p-6 sm:p-8">
          <div
            class="w-14 h-14 sm:w-16 sm:h-16 mx-auto rounded-2xl bg-gradient-to-br from-primary to-secondary flex items-center justify-center text-xl sm:text-2xl font-black text-white mb-5 sm:mb-6 shadow-lg shadow-primary/20 font-display"
          >
            2
          </div>
          <h3 class="text-lg sm:text-xl font-semibold text-text mb-3 font-display">Configure AI Agent</h3>
          <p class="text-text-muted text-sm sm:text-base">
            Set up your AI voice, conversation script, and goals. Our templates make it easy.
          </p>
        </div>
        <div class="relative text-center p-6 sm:p-8">
          <div
            class="w-14 h-14 sm:w-16 sm:h-16 mx-auto rounded-2xl bg-gradient-to-br from-primary to-secondary flex items-center justify-center text-xl sm:text-2xl font-black text-white mb-5 sm:mb-6 shadow-lg shadow-primary/20 font-display"
          >
            3
          </div>
          <h3 class="text-lg sm:text-xl font-semibold text-text mb-3 font-display">Launch & Monitor</h3>
          <p class="text-text-muted text-sm sm:text-base">
            Start your campaign and monitor results in real-time. AI handles the rest.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="relative py-16 sm:py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12 sm:mb-16">
        <span class="text-sm font-semibold text-primary uppercase tracking-wider">Industries</span>
        <h2 class="mt-3 text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold font-display text-text">
          Built for <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent"
            >every industry</span
          >
        </h2>
        <p class="mt-4 text-text-muted text-base sm:text-lg">
          AI voice agents tailored to the unique needs of your sector.
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-4">
        {
          [
            { name: 'Real Estate', slug: 'real-estate', icon: '🏠' },
            { name: 'Healthcare', slug: 'healthcare', icon: '🏥' },
            { name: 'Financial Services', slug: 'financial-services', icon: '💰' },
            { name: 'Insurance', slug: 'insurance', icon: '🛡️' },
            { name: 'Logistics', slug: 'logistics-transportation', icon: '🚛' },
            { name: 'Home Services', slug: 'home-services', icon: '🔧' },
            { name: 'Retail', slug: 'retail-consumer', icon: '🛒' },
            { name: 'Travel', slug: 'travel-hospitality', icon: '✈️' },
            { name: 'Debt Collection', slug: 'debt-collection', icon: '💼' },
            { name: 'Recruitment', slug: 'recruitment', icon: '👥' },
            { name: 'CRM Integration', slug: 'voice-ai-for-crms', icon: '🔗' },
            { name: 'Telecom', slug: 'telecom', icon: '📱' },
          ].map((industry) => (
            <a
              href={`/industries/${industry.slug}`}
              class="group p-4 sm:p-5 rounded-xl bg-surface-card border border-border hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 transition-all text-center"
            >
              <div class="text-2xl sm:text-3xl mb-2 sm:mb-3">{industry.icon}</div>
              <p class="text-xs sm:text-sm font-medium text-text group-hover:text-primary transition-colors">
                {industry.name}
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-16 sm:py-24 lg:py-32 overflow-hidden gradient-mesh">
    <div class="absolute inset-0">
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary/8 rounded-full blur-[150px]"
      >
      </div>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold font-display text-text mb-6">
        Ready to transform your <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent"
          >calling operations?</span
        >
      </h2>
      <p class="text-text-muted text-base sm:text-lg mb-8 sm:mb-10 max-w-2xl mx-auto">
        Start automating your outreach with Voxeia today. Try it free for 10 minutes.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="https://app.voxeia.com"
          class="w-full sm:w-auto px-8 sm:px-10 py-4 text-base font-semibold text-white bg-gradient-to-r from-primary to-primary-dark rounded-full hover:shadow-2xl hover:shadow-primary/30 transition-all hover:-translate-y-1 text-center"
        >
          Get Started for Free
        </a>
        <a
          href="/pricing"
          class="w-full sm:w-auto px-8 sm:px-10 py-4 text-base font-semibold text-text bg-surface-card border border-border rounded-full hover:border-primary/30 hover:shadow-lg transition-all text-center"
        >
          View Pricing
        </a>
      </div>
    </div>
  </section>

  <script>
    // Audio player
    const audioBtn = document.getElementById('audio-play-btn');
    const audio = document.getElementById('audio-sample') as HTMLAudioElement;
    const iconPlay = document.getElementById('audio-icon-play');
    const iconPause = document.getElementById('audio-icon-pause');
    const statusText = document.getElementById('audio-status');
    const bars = document.querySelectorAll('#audio-bars span');

    let isPlaying = false;

    audioBtn?.addEventListener('click', () => {
      if (!audio) return;
      if (isPlaying) {
        audio.pause();
        isPlaying = false;
        iconPlay?.classList.remove('hidden');
        iconPause?.classList.add('hidden');
        if (statusText) statusText.textContent = 'Paused';
        bars.forEach((b) => {
          (b as HTMLElement).style.animation = '';
          (b as HTMLElement).classList.remove('bg-primary');
          (b as HTMLElement).classList.add('bg-primary/30');
        });
      } else {
        audio.play();
        isPlaying = true;
        iconPlay?.classList.add('hidden');
        iconPause?.classList.remove('hidden');
        if (statusText) statusText.textContent = 'Playing...';
        bars.forEach((b, i) => {
          (b as HTMLElement).classList.remove('bg-primary/30');
          (b as HTMLElement).classList.add('bg-primary');
          (b as HTMLElement).style.animation = `audio-bar 0.5s ease-in-out ${i * 0.1}s infinite alternate`;
        });
      }
    });

    audio?.addEventListener('ended', () => {
      isPlaying = false;
      iconPlay?.classList.remove('hidden');
      iconPause?.classList.add('hidden');
      if (statusText) statusText.textContent = 'Click to play';
      bars.forEach((b) => {
        (b as HTMLElement).style.animation = '';
        (b as HTMLElement).classList.remove('bg-primary');
        (b as HTMLElement).classList.add('bg-primary/30');
      });
    });
  </script>

  <style>
    /* Hero animated background */
    .hero-animated-bg {
      background: linear-gradient(180deg, #f0f4ff 0%, #ffffff 100%);
    }
    .hero-orb-1 {
      background: rgba(19, 55, 236, 0.06);
      animation: orb-shift-1 8s ease-in-out infinite;
    }
    .hero-orb-2 {
      background: rgba(99, 102, 241, 0.05);
      animation: orb-shift-2 10s ease-in-out infinite;
    }
    .hero-orb-3 {
      background: rgba(19, 55, 236, 0.04);
      animation: orb-shift-3 12s ease-in-out infinite;
    }
    @keyframes orb-shift-1 {
      0%,
      100% {
        background: rgba(19, 55, 236, 0.06);
        transform: translate(0, 0);
      }
      33% {
        background: rgba(99, 102, 241, 0.06);
        transform: translate(30px, -20px);
      }
      66% {
        background: rgba(245, 158, 11, 0.04);
        transform: translate(-20px, 15px);
      }
    }
    @keyframes orb-shift-2 {
      0%,
      100% {
        background: rgba(99, 102, 241, 0.05);
        transform: translate(0, 0);
      }
      33% {
        background: rgba(245, 158, 11, 0.04);
        transform: translate(-25px, 20px);
      }
      66% {
        background: rgba(19, 55, 236, 0.06);
        transform: translate(15px, -25px);
      }
    }
    @keyframes orb-shift-3 {
      0%,
      100% {
        background: rgba(245, 158, 11, 0.04);
        transform: translate(-50%, -50%);
      }
      33% {
        background: rgba(19, 55, 236, 0.05);
        transform: translate(-45%, -55%);
      }
      66% {
        background: rgba(99, 102, 241, 0.05);
        transform: translate(-55%, -45%);
      }
    }
    @keyframes audio-bar {
      0% {
        height: 0.5rem;
      }
      100% {
        height: 1.5rem;
      }
    }
  </style>
</Layout>
