---
import Layout from '../layouts/Layout.astro';
import { Code, Zap, Terminal, ArrowRight } from '@lucide/astro';
import Icon from '../components/Icon.astro';

const integrations = [
  {
    name: 'Twilio',
    category: 'Telephony',
    description: 'Industry-leading cloud telephony powering every Voxeia call. Supports SMS, voice, and video.',
    icon: 'phone',
    status: 'Available',
  },
  {
    name: 'Vobiz',
    category: 'Telephony',
    description: 'India-focused telephony provider with DID numbers, IVR support, and local regulatory compliance.',
    icon: 'phone-call',
    status: 'Available',
  },
  {
    name: 'OpenAI',
    category: 'AI / LLM',
    description: 'GPT-4o and Whisper power our AI agents for natural conversations and real-time transcription.',
    icon: 'brain',
    status: 'Available',
  },
  {
    name: 'ElevenLabs',
    category: 'Voice / TTS',
    description: 'Ultra-realistic AI voice synthesis for natural-sounding agent voices in 30+ languages.',
    icon: 'volume-2',
    status: 'Available',
  },
  {
    name: 'Deepgram',
    category: 'Voice / STT',
    description: 'Enterprise speech-to-text with <300ms latency. Powers real-time call transcription.',
    icon: 'mic',
    status: 'Available',
  },
  {
    name: 'Salesforce',
    category: 'CRM',
    description: 'Sync call data, lead scores, and transcripts directly to Salesforce objects.',
    icon: 'cloud',
    status: 'Available',
  },
  {
    name: 'HubSpot',
    category: 'CRM',
    description: 'Auto-log calls, update deal stages, and trigger workflows based on AI call outcomes.',
    icon: 'database',
    status: 'Available',
  },
  {
    name: 'Zoho CRM',
    category: 'CRM',
    description: 'Native integration with Zoho CRM for Indian businesses. Sync contacts, calls, and notes.',
    icon: 'clipboard-list',
    status: 'Available',
  },
  {
    name: 'Zapier',
    category: 'Automation',
    description: 'Connect Voxeia to 5,000+ apps. Trigger calls from any event and push data anywhere.',
    icon: 'zap',
    status: 'Available',
  },
  {
    name: 'Slack',
    category: 'Communication',
    description: 'Get real-time call notifications, summaries, and alerts in your Slack channels.',
    icon: 'message-square',
    status: 'Available',
  },
  {
    name: 'Google Sheets',
    category: 'Data',
    description: 'Import contact lists from Google Sheets and export call results automatically.',
    icon: 'table',
    status: 'Available',
  },
  {
    name: 'Webhooks',
    category: 'Developer',
    description: 'Send real-time event data to any endpoint. Full control over call lifecycle events.',
    icon: 'link-2',
    status: 'Available',
  },
  {
    name: 'REST API',
    category: 'Developer',
    description: 'Full-featured REST API for programmatic access to all Voxeia capabilities.',
    icon: 'code',
    status: 'Available',
  },
  {
    name: 'WhatsApp Business',
    category: 'Communication',
    description: 'Send follow-up WhatsApp messages after calls with meeting links, summaries, and documents.',
    icon: 'message-circle',
    status: 'Coming Soon',
  },
  {
    name: 'Microsoft Teams',
    category: 'Communication',
    description: 'Transfer AI calls to Teams meetings and get call summaries posted to channels.',
    icon: 'users',
    status: 'Coming Soon',
  },
  {
    name: 'Freshsales',
    category: 'CRM',
    description: 'Native integration with Freshsales for contact sync, call logging, and deal tracking.',
    icon: 'user-check',
    status: 'Coming Soon',
  },
];

const categories = [...new Set(integrations.map((i) => i.category))];
---

<Layout
  title="Integrations"
  description="Connect Voxeia with your favorite tools — CRMs, telephony, AI, and 5,000+ apps via Zapier."
>
  <section class="relative pt-32 pb-16 overflow-hidden gradient-mesh">
    <div class="absolute inset-0 grid-pattern"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-sm font-semibold text-primary uppercase tracking-wider">Integrations</span>
      <h1 class="mt-3 text-4xl sm:text-5xl lg:text-6xl font-black font-display text-text">
        Connects with <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent"
          >everything</span
        >
      </h1>
      <p class="mt-4 text-lg text-text-muted max-w-2xl mx-auto">
        Voxeia integrates seamlessly with your existing tech stack — CRMs, telephony providers, AI engines, and
        thousands more via API and Zapier.
      </p>
    </div>
  </section>

  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap justify-center gap-3" id="category-filters">
        <button
          class="px-5 py-2 rounded-full text-sm font-semibold bg-gradient-to-r from-primary to-primary-dark text-white transition-all"
          data-category="all">All</button
        >
        {
          categories.map((cat) => (
            <button
              class="px-5 py-2 rounded-full text-sm font-semibold text-text-muted bg-surface-raised border border-border hover:border-primary/30 transition-all"
              data-category={cat}
            >
              {cat}
            </button>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" id="integrations-grid">
        {
          integrations.map((int) => (
            <div
              class="integration-card p-6 rounded-2xl bg-surface-card border border-border hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 transition-all group"
              data-category={int.category}
            >
              <div class="flex items-center justify-between mb-4">
                <div class="p-2 rounded-xl bg-primary/10">
                  <Icon name={int.icon} class="w-6 h-6 text-primary" />
                </div>
                <span
                  class:list={[
                    'text-xs px-3 py-1 rounded-full font-medium',
                    int.status === 'Available' ? 'bg-success/10 text-success' : 'bg-secondary/10 text-secondary',
                  ]}
                >
                  {int.status}
                </span>
              </div>
              <h3 class="text-lg font-bold font-display text-text group-hover:text-primary transition-colors">
                {int.name}
              </h3>
              <p class="text-xs text-text-light uppercase tracking-wider mt-1">{int.category}</p>
              <p class="mt-3 text-sm text-text-muted leading-relaxed">{int.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-24 bg-surface-alt border-y border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="p-8 rounded-2xl bg-surface-card border border-border text-center">
          <div class="p-4 rounded-2xl bg-primary/10 w-fit mx-auto mb-4">
            <Code class="w-8 h-8 text-primary" />
          </div>
          <h3 class="text-xl font-bold font-display text-text">REST API</h3>
          <p class="mt-2 text-text-muted text-sm">
            Full API access to trigger calls, manage agents, and retrieve analytics programmatically.
          </p>
          <a href="/contact" class="mt-4 inline-block text-primary text-sm font-semibold hover:underline"
            >View API Docs →</a
          >
        </div>
        <div class="p-8 rounded-2xl bg-surface-card border border-border text-center">
          <div class="p-4 rounded-2xl bg-secondary/10 w-fit mx-auto mb-4">
            <Zap class="w-8 h-8 text-secondary" />
          </div>
          <h3 class="text-xl font-bold font-display text-text">Webhooks</h3>
          <p class="mt-2 text-text-muted text-sm">
            Real-time event delivery for call started, completed, transferred, and more.
          </p>
          <a href="/contact" class="mt-4 inline-block text-primary text-sm font-semibold hover:underline"
            >Setup Guide →</a
          >
        </div>
        <div class="p-8 rounded-2xl bg-surface-card border border-border text-center">
          <div class="p-4 rounded-2xl bg-accent/10 w-fit mx-auto mb-4">
            <Terminal class="w-8 h-8 text-accent" />
          </div>
          <h3 class="text-xl font-bold font-display text-text">Custom Integration</h3>
          <p class="mt-2 text-text-muted text-sm">
            Need a custom integration? Our team can build it for you as part of Enterprise onboarding.
          </p>
          <a href="/contact" class="mt-4 inline-block text-primary text-sm font-semibold hover:underline"
            >Contact Sales →</a
          >
        </div>
      </div>
    </div>
  </section>

  <section class="py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold font-display text-text">Need an integration we don't have?</h2>
      <p class="mt-4 text-lg text-text-muted">We're always adding new integrations. Let us know what you need.</p>
      <a
        href="/contact"
        class="mt-8 inline-flex items-center gap-2 px-8 py-4 text-white font-semibold bg-gradient-to-r from-primary to-primary-dark rounded-full hover:shadow-lg hover:shadow-primary/25 transition-all hover:-translate-y-0.5"
      >
        Request Integration
        <ArrowRight class="w-5 h-5" />
      </a>
    </div>
  </section>

  <script>
    const buttons = document.querySelectorAll('#category-filters button');
    const cards = document.querySelectorAll('.integration-card');
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => {
          b.classList.remove('bg-gradient-to-r', 'from-primary', 'to-primary-dark', 'text-white');
          b.classList.add('text-text-muted', 'bg-surface-raised', 'border', 'border-border');
        });
        btn.classList.add('bg-gradient-to-r', 'from-primary', 'to-primary-dark', 'text-white');
        btn.classList.remove('text-text-muted', 'bg-surface-raised');
        const cat = (btn as HTMLElement).dataset.category;
        cards.forEach((card) => {
          const el = card as HTMLElement;
          if (cat === 'all' || el.dataset.category === cat) {
            el.style.display = '';
          } else {
            el.style.display = 'none';
          }
        });
      });
    });
  </script>
</Layout>
