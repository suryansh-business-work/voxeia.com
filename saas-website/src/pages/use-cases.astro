---
import Layout from '../layouts/Layout.astro';
import { useCases } from '../data/use-cases';
import { ChevronRight } from '@lucide/astro';

const ucIcons: Record<string, string> = {
  'lead-qualification': '🎯',
  'lead-generation': '📈',
  'customer-support': '🛟',
  'ai-receptionist': '🤖',
  'call-follow-up-automation': '🔄',
  'abandoned-cart-recovery': '🛒',
  'product-announcements': '📢',
  'survey-nps-calls': '📊',
  'payment-reminders': '💳',
};
---

<Layout
  title="Use Cases"
  description="Discover how Voxeia AI voice agents automate calls across every business function."
>
  <section class="relative pt-32 pb-16 overflow-hidden gradient-mesh">
    <div class="absolute inset-0 grid-pattern"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-sm font-semibold text-primary uppercase tracking-wider">Use Cases</span>
      <h1 class="mt-3 text-4xl sm:text-5xl lg:text-6xl font-black font-display text-text">
        One platform, <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent"
          >endless possibilities</span
        >
      </h1>
      <p class="mt-4 text-lg text-text-muted max-w-2xl mx-auto">
        From lead qualification to payment reminders, Voxeia automates every type of business call with human-like AI
        agents.
      </p>
    </div>
  </section>

  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          useCases.map((uc) => (
            <a
              href={`/use-cases/${uc.slug}`}
              class="group p-8 rounded-2xl bg-surface-card border border-border hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all hover:-translate-y-1"
            >
              <div class="text-4xl mb-4">{ucIcons[uc.slug] || '📞'}</div>
              <h3 class="text-xl font-bold font-display text-text group-hover:text-primary transition-colors">
                {uc.name}
              </h3>
              <p class="mt-3 text-text-muted leading-relaxed">{uc.description}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {uc.benefits.slice(0, 2).map((b) => (
                  <span class="text-xs px-3 py-1 rounded-full bg-primary/10 text-primary font-medium">
                    {b.metric} {b.label}
                  </span>
                ))}
              </div>
              <span class="mt-6 inline-flex items-center text-sm text-primary font-semibold">
                Learn more
                <ChevronRight class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" />
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-24 bg-surface-alt border-t border-border">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold font-display text-text">Don't see your use case?</h2>
      <p class="mt-4 text-lg text-text-muted">
        Our AI agents are fully customizable. Tell us what you need, and we'll build it.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a
          href="/contact"
          class="px-8 py-4 text-white font-semibold bg-gradient-to-r from-primary to-primary-dark rounded-full hover:shadow-lg hover:shadow-primary/25 transition-all hover:-translate-y-0.5"
          >Talk to Us</a
        >
        <a
          href="/pricing"
          class="px-8 py-4 text-text font-semibold bg-surface-raised border border-border rounded-full hover:border-primary/30 transition-all hover:-translate-y-0.5"
          >View Pricing</a
        >
      </div>
    </div>
  </section>
</Layout>
