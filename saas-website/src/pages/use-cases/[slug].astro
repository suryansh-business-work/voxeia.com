---
import Layout from '../../layouts/Layout.astro';
import { useCases, type UseCase } from '../../data/use-cases';
import { ChevronRight } from '@lucide/astro';
import Icon from '../../components/Icon.astro';

export function getStaticPaths() {
  return useCases.map((uc) => ({
    params: { slug: uc.slug },
    props: { useCase: uc },
  }));
}

interface Props {
  useCase: UseCase;
}
const { useCase } = Astro.props;

const otherUseCases = useCases.filter((u) => u.slug !== useCase.slug).slice(0, 4);
---

<Layout title={`${useCase.name} - AI Voice Automation`} description={useCase.description}>
  <!-- Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden gradient-mesh">
    <div class="absolute inset-0 grid-pattern"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl">
        <nav class="flex items-center gap-2 text-sm text-text-muted mb-6">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span>/</span>
          <a href="/use-cases" class="hover:text-primary transition-colors">Use Cases</a>
          <span>/</span>
          <span class="text-text">{useCase.name}</span>
        </nav>
        <span class="text-sm font-semibold text-primary uppercase tracking-wider">Use Case</span>
        <h1 class="mt-3 text-4xl sm:text-5xl lg:text-6xl font-black font-display text-text leading-tight">
          {useCase.tagline}
        </h1>
        <p class="mt-6 text-lg text-text-muted leading-relaxed max-w-3xl">{useCase.heroDescription}</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a
            href="/"
            class="px-8 py-4 text-white font-semibold bg-gradient-to-r from-primary to-primary-dark rounded-full hover:shadow-lg hover:shadow-primary/25 transition-all hover:-translate-y-0.5"
            >Try It Free</a
          >
          <a
            href="/contact"
            class="px-8 py-4 text-text font-semibold bg-surface-raised border border-border rounded-full hover:border-primary/30 transition-all hover:-translate-y-0.5"
            >Request Demo</a
          >
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Stats -->
  <section class="py-20 bg-surface-alt border-y border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {
          useCase.benefits.map((b) => (
            <div class="text-center">
              <div class="text-4xl sm:text-5xl font-black font-display bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">
                {b.metric}
              </div>
              <p class="mt-2 text-sm text-text-muted">{b.label}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <span class="text-sm font-semibold text-primary uppercase tracking-wider">How It Works</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold font-display text-text">Simple setup, powerful results</h2>
      </div>
      <div class="max-w-4xl mx-auto">
        <div class="relative">
          <div
            class="absolute left-8 top-0 bottom-0 w-px bg-gradient-to-b from-primary via-secondary to-primary/0 hidden md:block"
          >
          </div>
          <div class="space-y-12">
            {
              useCase.howItWorks.map((step) => (
                <div class="relative flex items-start gap-8">
                  <div class="hidden md:flex shrink-0 w-16 h-16 rounded-2xl bg-gradient-to-br from-primary to-secondary items-center justify-center text-white text-xl font-black font-display z-10">
                    {step.step}
                  </div>
                  <div class="flex-1 p-8 rounded-2xl bg-surface-card border border-border hover:shadow-lg hover:shadow-primary/5 transition-all">
                    <div class="md:hidden inline-flex w-10 h-10 rounded-xl bg-gradient-to-br from-primary to-secondary items-center justify-center text-white text-sm font-bold mb-4">
                      {step.step}
                    </div>
                    <h3 class="text-xl font-bold font-display text-text mb-2">{step.title}</h3>
                    <p class="text-text-muted leading-relaxed">{step.description}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-24 bg-surface-alt border-y border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <span class="text-sm font-semibold text-primary uppercase tracking-wider">Features</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold font-display text-text">
          Built for {useCase.name.toLowerCase()}
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {
          useCase.features.map((feat) => (
            <div class="p-8 rounded-2xl bg-surface-card border border-border hover:shadow-lg hover:shadow-primary/5 transition-all group">
              <div class="p-3 rounded-xl bg-primary/10 w-fit mb-4 group-hover:bg-primary/20 transition-colors">
                <Icon name={feat.icon} class="w-6 h-6 text-primary" />
              </div>
              <h3 class="text-xl font-bold font-display text-text mb-3">{feat.title}</h3>
              <p class="text-text-muted leading-relaxed">{feat.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="text-sm font-semibold text-primary uppercase tracking-wider">Industries</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold font-display text-text">Popular across industries</h2>
        <p class="mt-3 text-text-muted">{useCase.name} is widely used in these sectors</p>
      </div>
      <div class="flex flex-wrap justify-center gap-4">
        {
          useCase.industries.map((ind) => (
            <span class="px-6 py-3 rounded-full bg-surface-card border border-border text-text-muted">{ind}</span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Other Use Cases -->
  <section class="py-24 bg-surface-alt border-y border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold font-display text-text">Explore other use cases</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          otherUseCases.map((uc) => (
            <a
              href={`/use-cases/${uc.slug}`}
              class="p-6 rounded-2xl bg-surface-card border border-border hover:border-primary/30 hover:shadow-lg hover:shadow-primary/5 transition-all group"
            >
              <h3 class="text-lg font-bold text-text group-hover:text-primary transition-colors">{uc.name}</h3>
              <p class="mt-2 text-sm text-text-muted line-clamp-2">{uc.description}</p>
              <span class="mt-3 inline-flex items-center text-sm text-primary font-semibold">
                Learn more
                <ChevronRight class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" />
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold font-display text-text">
        Ready to automate {useCase.name.toLowerCase()}?
      </h2>
      <p class="mt-4 text-lg text-text-muted">Start your free trial today. No credit card required.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a
          href="/"
          class="px-8 py-4 text-white font-semibold bg-gradient-to-r from-primary to-primary-dark rounded-full hover:shadow-lg hover:shadow-primary/25 transition-all hover:-translate-y-0.5"
          >Get Started Free</a
        >
        <a
          href="/contact"
          class="px-8 py-4 text-text font-semibold bg-surface-raised border border-border rounded-full hover:border-primary/30 transition-all hover:-translate-y-0.5"
          >Talk to Sales</a
        >
      </div>
    </div>
  </section>
</Layout>
